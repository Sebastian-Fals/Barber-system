# === BASE DE DATOS (Neon PostgreSQL) ===
# Formato: postgresql://usuario:password@host/nombre_db
DATABASE_URL="postgresql://neondb_owner:password@ep-cool-db.us-east-2.aws.neon.tech/neondb?sslmode=require"

# === WHATSAPP API ===
WHATSAPP_API_TOKEN="EAAG..."
WHATSAPP_VERIFY_TOKEN="tu_token_verificacion"

# === GOOGLE INTEGRATION ===
# Ruta relativa o absoluta al archivo JSON de credenciales
GOOGLE_APPLICATION_CREDENTIALS="credentials.json"
# (Opcional) API Key para Gemini Flash si se usa
GOOGLE_API_KEY="AIza..."

# === GOOGLE CALENDAR WEBHOOK ===
# URL pública (ngrok o dominio real) donde Google enviará notificaciones
WEBHOOK_PUBLIC_URL="https://tu-app.ngrok-free.app/api/v1/google-webhook"

# === APP CONFIG ===
TIMEZONE="America/Bogota"
